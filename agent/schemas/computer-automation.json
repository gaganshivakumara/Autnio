{
  "openapi": "3.0.0",
  "info": { "title": "Computer Automation", "version": "1.0.0" },
  "paths": {
    "/dispatch": {
      "post": {
        "summary": "Dispatch automation task to Open Interpreter",
        "operationId": "dispatchAutomationTask",
        "description": "Send a computer automation task to Open Interpreter on the user's machine",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["task", "userId"],
                "properties": {
                  "task": { "type": "string", "description": "Natural language task description" },
                  "userId": { "type": "string" },
                  "sessionId": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Task dispatched successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": { "type": "string" },
                    "data": { "type": "object" }
                  }
                }
              }
            }
          },
          "503": { "description": "Open Interpreter not reachable" }
        }
      }
    }
  }
}
