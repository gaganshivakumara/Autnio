{
  "openapi": "3.0.0",
  "info": { "title": "Web Research", "version": "1.0.0" },
  "paths": {
    "/scrape": {
      "post": {
        "summary": "Run Apify web scrape",
        "operationId": "scrapeWeb",
        "description": "Trigger an Apify actor and return structured results",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["actorId", "userId"],
                "properties": {
                  "actorId": { "type": "string", "description": "Apify actor ID" },
                  "userId": { "type": "string" },
                  "input": { "type": "object", "description": "Actor input payload" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Scrape completed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": { "type": "string" },
                    "data": { "type": "object" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
